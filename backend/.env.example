# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:1234@localhost:5432/invisionu?sslmode=disable

# Server port
PORT=8080

# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# Frontend origin for CORS (comma-separated for multiple)
# Production: set to your Railway frontend URL, e.g. https://frontend.up.railway.app
ALLOW_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# AI PROVIDERS
# ─────────────────────────────────────────────────────────────────────────────

# Default AI provider: "gemini" or "ollama"
AI_PROVIDER=gemini

# Google Gemini API key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Ollama (local, optional)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b

# ─────────────────────────────────────────────────────────────────────────────
# TELEGRAM BOT (Stage 2 Interview)
# ─────────────────────────────────────────────────────────────────────────────

TELEGRAM_BOT_TOKEN=
WHISPER_API_KEY=
ALEM_STT_API_KEY=
WHISPER_PROVIDER=openai

# Interview settings
INTERVIEW_TIMEOUT_MIN=30
INTERVIEW_MIN_QUESTIONS=8
INTERVIEW_MAX_QUESTIONS=15

# ─────────────────────────────────────────────────────────────────────────────
# FILE UPLOADS
# ─────────────────────────────────────────────────────────────────────────────

UPLOAD_DIR=./uploads

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL (SMTP)
# ─────────────────────────────────────────────────────────────────────────────

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@invisionu.kz

# ─────────────────────────────────────────────────────────────────────────────
# RAILWAY DEPLOYMENT CHECKLIST
# Set these as Environment Variables in your Railway backend service:
#
#   DATABASE_URL    → Auto-injected when you link a Postgres service in Railway.
#                     In Railway: "Add Variable Reference" → select Postgres → DATABASE_URL
#
#   PORT            → Auto-injected by Railway (do NOT set manually)
#
#   JWT_SECRET      → Generate: openssl rand -hex 32
#
#   GEMINI_API_KEY  → Your Gemini API key
#
#   ALLOW_ORIGINS   → Your Railway frontend URL, e.g. https://myapp-frontend.up.railway.app
#                     Or use * to allow all origins (less secure)
#
#   TELEGRAM_BOT_TOKEN → Your Telegram bot token (if using Stage 2 interviews)
#
#   UPLOAD_DIR      → /app/uploads  (use persistent volume in Railway for uploads)
# ─────────────────────────────────────────────────────────────────────────────
