# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT
# Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_API_URL=http://localhost:8080/api

# ─────────────────────────────────────────────────────────────────────────────
# RAILWAY DEPLOYMENT CHECKLIST
#
# NEXT_PUBLIC_API_URL is baked into the frontend at BUILD TIME (Next.js requirement).
# You MUST set it as a Build Argument in Railway, not just an env var:
#
#   Railway → Frontend Service → Settings → Build → Build Arguments:
#     NEXT_PUBLIC_API_URL = https://your-backend.up.railway.app/api
#
# The backend URL is shown in Railway under your backend service → Settings → Domains.
# Make sure to add /api at the end!
# ─────────────────────────────────────────────────────────────────────────────
